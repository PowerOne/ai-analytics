// Learning Analytics API — Prisma schema aligned with unified SQL model
// https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PRINCIPAL
  TEACHER
}

/// API login identity; scoped to exactly one school.
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  schoolId     String   @map("school_id") @db.Uuid
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  role         UserRole
  teacherId    String?  @map("teacher_id") @db.Uuid
  teacher      Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([schoolId])
  @@map("users")
}

model School {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String?   @unique
  timezone  String    @default("UTC")
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users             User[]
  teachers          Teacher[]
  students          Student[]
  subjects          Subject[]
  academicYears     AcademicYear[]
  terms             Term[]
  classes           Class[]
  enrollments       Enrollment[]
  assessments       Assessment[]
  assessmentResults AssessmentResult[]
  attendanceRecords AttendanceRecord[]
  lmsActivityEvents LmsActivityEvent[]
  dataSources       DataSource[]
  interventions     Intervention[]

  @@map("schools")
}

model AcademicYear {
  id        String    @id @default(uuid()) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  label     String
  startsOn  DateTime  @map("starts_on") @db.Date
  endsOn    DateTime  @map("ends_on") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  terms Term[]

  @@unique([schoolId, id])
  @@index([schoolId])
  @@map("academic_years")
}

model Term {
  id             String       @id @default(uuid()) @db.Uuid
  schoolId       String       @map("school_id") @db.Uuid
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYearId String       @map("academic_year_id") @db.Uuid
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  label          String
  sequenceNo     Int          @default(1) @map("sequence_no")
  startsOn       DateTime     @map("starts_on") @db.Date
  endsOn         DateTime     @map("ends_on") @db.Date
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  classes Class[]

  @@unique([schoolId, id])
  @@index([schoolId])
  @@map("terms")
}

model Teacher {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @map("school_id") @db.Uuid
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  externalSource String?   @map("external_source")
  externalId     String?   @map("external_id")
  givenName      String?   @map("given_name")
  familyName     String?   @map("family_name")
  displayName    String?   @map("display_name")
  email          String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  users          User[]
  primaryClasses Class[]        @relation("PrimaryTeacher")
  interventions  Intervention[]

  @@unique([schoolId, id])
  @@index([schoolId])
  @@map("teachers")
}

model Student {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @map("school_id") @db.Uuid
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  externalSource String?   @map("external_source")
  externalId     String?   @map("external_id")
  givenName      String?   @map("given_name")
  familyName     String?   @map("family_name")
  displayName    String?   @map("display_name")
  email          String?
  gradeLevel     String?   @map("grade_level")
  cohortYear     Int?      @map("cohort_year")
  demographics   Json      @default("{}")
  metadata       Json      @default("{}")
  performance    Float?
  attendance     Float?
  engagement     Float?
  riskScore      Float?    @map("risk_score")
  deltas         Json      @default("{}")
  tiers          Json      @default("{}")
  flags          Json      @default("{}")
  stability      Float?
  classId        String?   @map("class_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  enrollments       Enrollment[]
  assessmentResults AssessmentResult[]
  attendanceRecords AttendanceRecord[]
  lmsActivityEvents LmsActivityEvent[]
  interventions     Intervention[]

  @@unique([schoolId, id])
  @@index([schoolId])
  @@map("students")
}

model Subject {
  id        String    @id @default(uuid()) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  code      String
  name      String
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  classes Class[]

  @@unique([schoolId, id])
  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("subjects")
}

model Class {
  id               String    @id @default(uuid()) @db.Uuid
  schoolId         String    @map("school_id") @db.Uuid
  school           School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjectId        String    @map("subject_id") @db.Uuid
  subject          Subject   @relation(fields: [subjectId], references: [id])
  termId           String    @map("term_id") @db.Uuid
  term             Term      @relation(fields: [termId], references: [id])
  sectionCode      String?   @map("section_code")
  name             String
  primaryTeacherId String?   @map("primary_teacher_id") @db.Uuid
  primaryTeacher   Teacher?  @relation("PrimaryTeacher", fields: [primaryTeacherId], references: [id])
  room             String?
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  enrollments       Enrollment[]
  assessments       Assessment[]
  attendanceRecords AttendanceRecord[]
  lmsActivityEvents LmsActivityEvent[]
  interventions     Intervention[]

  @@unique([schoolId, id])
  @@index([schoolId, termId])
  @@map("classes")
}

model Enrollment {
  id         String    @id @default(uuid()) @db.Uuid
  schoolId   String    @map("school_id") @db.Uuid
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId  String    @map("student_id") @db.Uuid
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId    String    @map("class_id") @db.Uuid
  class      Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  role       String    @default("student")
  status     String    @default("active")
  enrolledOn DateTime? @map("enrolled_on") @db.Date
  metadata   Json      @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@unique([schoolId, id])
  @@unique([schoolId, studentId, classId])
  @@index([schoolId, studentId])
  @@index([schoolId, classId])
  @@map("enrollments")
}

model Assessment {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @map("school_id") @db.Uuid
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId        String?   @map("class_id") @db.Uuid
  class          Class?    @relation(fields: [classId], references: [id])
  title          String
  assessmentType String    @default("other") @map("assessment_type")
  maxScore       Decimal?  @map("max_score") @db.Decimal(12, 4)
  administeredOn DateTime? @map("administered_on") @db.Date
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  results AssessmentResult[]

  @@unique([schoolId, id])
  @@index([schoolId, classId])
  @@map("assessments")
}

model AssessmentResult {
  id           String     @id @default(uuid()) @db.Uuid
  schoolId     String     @map("school_id") @db.Uuid
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assessmentId String     @map("assessment_id") @db.Uuid
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId    String     @map("student_id") @db.Uuid
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scoreRaw     Decimal?   @map("score_raw") @db.Decimal(12, 4)
  scorePercent Decimal?   @map("score_percent") @db.Decimal(7, 4)
  attemptNo    Int        @default(1) @map("attempt_no")
  submittedAt  DateTime?  @map("submitted_at")
  metadata     Json       @default("{}")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  @@unique([schoolId, id])
  @@unique([schoolId, assessmentId, studentId, attemptNo])
  @@index([schoolId, studentId])
  @@map("assessment_results")
}

model AttendanceRecord {
  id           String    @id @default(uuid()) @db.Uuid
  schoolId     String    @map("school_id") @db.Uuid
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId      String    @map("class_id") @db.Uuid
  class        Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId    String    @map("student_id") @db.Uuid
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sessionDate  DateTime  @map("session_date") @db.Date
  sessionIndex Int       @default(1) @map("session_index")
  status       String    @default("present")
  source       String    @default("manual")
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@unique([schoolId, id])
  @@unique([schoolId, classId, studentId, sessionDate, sessionIndex])
  @@index([schoolId, classId, sessionDate])
  @@index([schoolId, studentId, sessionDate])
  @@map("attendance_records")
}

model LmsActivityEvent {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId       String    @map("student_id") @db.Uuid
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId         String?   @map("class_id") @db.Uuid
  class           Class?    @relation(fields: [classId], references: [id])
  occurredAt      DateTime  @map("occurred_at")
  eventType       String    @map("event_type")
  durationSeconds Int?      @map("duration_seconds")
  engagementScore Decimal?  @map("engagement_score") @db.Decimal(8, 4)
  payload         Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@unique([schoolId, id])
  @@index([schoolId, studentId, occurredAt])
  @@index([schoolId, classId, occurredAt])
  @@map("lms_activity_events")
}

model DataSource {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  type      String // "MIS", "LMS", "CSV", "API"
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mappings   FieldMapping[]
  importJobs ImportJob[]

  @@index([schoolId])
  @@map("data_sources")
}

model FieldMapping {
  id           String     @id @default(uuid()) @db.Uuid
  dataSourceId String     @map("data_source_id") @db.Uuid
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  targetModel  String
  targetField  String
  sourceField  String
  transform    String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@index([dataSourceId])
  @@map("field_mappings")
}

model ImportJob {
  id           String     @id @default(uuid()) @db.Uuid
  dataSourceId String     @map("data_source_id") @db.Uuid
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  status       String     @default("pending")
  rowCount     Int?       @map("row_count")
  errorCount   Int?       @map("error_count")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  errors ImportJobError[]

  @@index([dataSourceId])
  @@map("import_jobs")
}

model ImportJobError {
  id          String    @id @default(uuid()) @db.Uuid
  importJobId String    @map("import_job_id") @db.Uuid
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowNumber   Int
  message     String
  rawData     Json
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([importJobId])
  @@map("import_job_errors")
}

/// Rule- or manually-created interventions for at-risk classes/students.
model Intervention {
  id              String   @id @default(cuid())
  schoolId        String   @map("school_id") @db.Uuid
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId       String   @map("teacher_id") @db.Uuid
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classId         String?  @map("class_id") @db.Uuid
  class           Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  studentId       String?  @map("student_id") @db.Uuid
  student         Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  triggerType     String   @map("trigger_type")
  description     String
  notes           String?  @db.Text
  recommendations Json?
  status          String   @default("open") @map("status") // open | in_progress | resolved
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([schoolId])
  @@index([teacherId])
  @@index([status])
  @@map("interventions")
}

// -------------------------------------
// Weekly Student Snapshot
// -------------------------------------
model WeeklyStudentSnapshot {
  id            String   @id @default(cuid())
  schoolId      String   @db.Uuid
  studentId     String   @db.Uuid
  weekStartDate DateTime // Monday UTC of the week

  performance Float?
  attendance  Float?
  engagement  Float?
  riskScore   Float?
  riskTier    String? // "LOW" | "MEDIUM" | "HIGH"

  riskComposite Float?
  riskCategory  String?
  riskReasons   Json?
  riskStability Float?
  riskDeltas    Json?

  createdAt DateTime @default(now())

  @@index([schoolId, weekStartDate])
  @@index([schoolId, studentId, weekStartDate])
  @@map("weekly_student_snapshots")
}

// -------------------------------------
// Weekly Class Snapshot
// -------------------------------------
model WeeklyClassSnapshot {
  id            String   @id @default(cuid())
  schoolId      String   @db.Uuid
  classId       String   @db.Uuid
  weekStartDate DateTime

  performance Float?
  attendance  Float?
  engagement  Float?
  riskScore   Float?

  riskComposite Float?
  riskCategory  String?
  riskReasons   Json?
  riskStability Float?
  riskDeltas    Json?

  createdAt DateTime @default(now())

  @@index([schoolId, weekStartDate])
  @@index([schoolId, classId, weekStartDate])
  @@map("weekly_class_snapshots")
}

// -------------------------------------
// Weekly Cohort Snapshot (grade + subject)
// -------------------------------------
model WeeklyCohortSnapshot {
  id            String   @id @default(cuid())
  schoolId      String   @db.Uuid
  cohortType    String // "GRADE" | "SUBJECT"
  cohortId      String // gradeKey or subjectId
  name          String
  weekStartDate DateTime

  performance Float?
  attendance  Float?
  engagement  Float?

  riskLow     Int?
  riskMedium  Int?
  riskHigh    Int?
  riskAverage Float?

  interventions Int?

  createdAt DateTime @default(now())

  @@index([schoolId, weekStartDate])
  @@index([schoolId, cohortType, cohortId, weekStartDate])
  @@map("weekly_cohort_snapshots")
}

// -------------------------------------
// Weekly School Snapshot
// -------------------------------------
model WeeklySchoolSnapshot {
  id            String   @id @default(cuid())
  schoolId      String   @db.Uuid
  weekStartDate DateTime

  performance Float?
  attendance  Float?
  engagement  Float?

  riskLow     Int?
  riskMedium  Int?
  riskHigh    Int?
  riskAverage Float?

  interventionsCreated  Int?
  interventionsResolved Int?

  riskComposite Float?
  riskCategory  String?
  riskReasons   Json?
  riskStability Float?
  riskDeltas    Json?

  createdAt DateTime @default(now())

  @@index([schoolId, weekStartDate])
  @@map("weekly_school_snapshots")
}
