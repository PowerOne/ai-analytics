# Backend origin (server-side). Preferred so the browser never needs the raw API URL.
API_URL=http://localhost:3001

# Fallback / client direct login (localStorage strategy). No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Must match apps/api JWT_SECRET — required for middleware and /api/auth/* verification.
JWT_SECRET=change-me-in-dev

# Omit or set to "localStorage" to login directly against NEXT_PUBLIC_API_URL, then sync HttpOnly session.
# NEXT_PUBLIC_AUTH_STRATEGY=localStorage
