# Copy to .env and: docker compose --env-file .env up -d
MYSQL_ROOT_PASSWORD=analytics
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_DAYS=7
CORS_ORIGIN=http://localhost:3000
# Same value for api (caller) and ai (validator) — leave empty for local dev without locking /predict
INTERNAL_API_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Web container only: Next server → API over Docker network (override if service name/port differs)
# API_INTERNAL_URL=http://api:3001/api
